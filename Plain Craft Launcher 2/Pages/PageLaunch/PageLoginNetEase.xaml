<Grid x:Class="PCL.PageLoginNetEase" Tag="False"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:PCL"
      mc:Ignorable="d"
      d:DesignWidth="360"
      d:DesignHeight="620">
    <local:MyScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
        <StackPanel x:Name="PanRoot" Margin="4,0,4,8">
            <TextBlock Text="平台"
                       Margin="4,0,0,8"
                       Opacity="0.72"
                       FontSize="12" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <local:MyButton x:Name="BtnPlatformNetease"
                                Grid.Column="0"
                                Height="34"
                                ColorType="Highlight"
                                Text="Netease" />
                <local:MyButton x:Name="BtnPlatform4399"
                                Grid.Column="2"
                                Height="34"
                                ColorType="Normal"
                                Text="4399" />
            </Grid>

            <local:MyCard Title="Netease 登录方式"
                          Margin="0,14,0,0">
                <StackPanel Margin="16,42,16,16">
                    <TextBlock x:Name="LabMethodDescription"
                               Opacity="0.78"
                               TextWrapping="Wrap" />
                    <local:MyButton x:Name="BtnMethodEmail"
                                    Height="34"
                                    Margin="0,14,0,0"
                                    ColorType="Highlight"
                                    Text="邮箱 + 密码" />
                    <local:MyButton x:Name="BtnMethodSms"
                                    Height="34"
                                    Margin="0,8,0,0"
                                    ColorType="Normal"
                                    Text="手机号 + 验证码" />
                    <local:MyButton x:Name="BtnMethodCookie"
                                    Height="34"
                                    Margin="0,8,0,0"
                                    ColorType="Normal"
                                    Text="Cookie 登录" />
                </StackPanel>
            </local:MyCard>

            <local:MyCard x:Name="CardEmailLogin"
                          Title="Netease 邮箱登录"
                          Margin="0,14,0,0">
                <StackPanel Margin="16,42,16,16">
                    <TextBlock Text="直接使用网易邮箱和密码登录。"
                               Opacity="0.78"
                               TextWrapping="Wrap" />
                    <local:MyTextBox x:Name="TextEmail"
                                     Height="32"
                                     Margin="0,14,0,0"
                                     HintText="网易邮箱" />
                    <PasswordBox x:Name="TextEmailPass"
                                 Height="32"
                                 Margin="0,10,0,0" />
                    <local:MyButton x:Name="BtnEmailLogin"
                                    Height="36"
                                    Margin="0,18,0,0"
                                    ColorType="Highlight"
                                    Text="登录 Netease" />
                </StackPanel>
            </local:MyCard>

            <local:MyCard x:Name="CardSmsLogin"
                          Title="Netease 手机号验证码登录"
                          Visibility="Collapsed"
                          Margin="0,14,0,0">
                <StackPanel Margin="16,42,16,16">
                    <TextBlock Text="先发送验证码，再使用手机号和验证码登录。"
                               Opacity="0.78"
                               TextWrapping="Wrap" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="110" />
                        </Grid.ColumnDefinitions>
                        <local:MyTextBox x:Name="TextSmsPhone"
                                         Grid.Column="0"
                                         Height="32"
                                         HintText="手机号" />
                        <local:MyButton x:Name="BtnSendCode"
                                        Grid.Column="2"
                                        Height="32"
                                        ColorType="Normal"
                                        Text="发送验证码" />
                    </Grid>
                    <local:MyTextBox x:Name="TextSmsCode"
                                     Height="32"
                                     Margin="0,10,0,0"
                                     HintText="短信验证码" />
                    <local:MyButton x:Name="BtnSmsLogin"
                                    Height="36"
                                    Margin="0,18,0,0"
                                    ColorType="Highlight"
                                    Text="验证并登录" />
                </StackPanel>
            </local:MyCard>

            <local:MyCard x:Name="CardCookieLogin"
                          Title="Netease Cookie 登录"
                          Visibility="Collapsed"
                          Margin="0,14,0,0">
                <StackPanel Margin="16,42,16,16">
                    <TextBlock Text="把已经拿到的 Netease 会话 Cookie 贴进来。"
                               Opacity="0.78"
                               TextWrapping="Wrap" />
                    <local:MyTextBox x:Name="TextCookieName"
                                     Height="32"
                                     Margin="0,14,0,0"
                                     HintText="档案名称（可选）" />
                    <local:MyTextBox x:Name="TextCookie"
                                     MinHeight="96"
                                     Margin="0,10,0,0"
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top"
                                     TextWrapping="Wrap"
                                     HintText="粘贴完整 Cookie" />
                    <local:MyButton x:Name="BtnCookieLogin"
                                    Height="36"
                                    Margin="0,18,0,0"
                                    ColorType="Highlight"
                                    Text="登录 Cookie" />
                </StackPanel>
            </local:MyCard>
        </StackPanel>
    </local:MyScrollViewer>
</Grid>
