<local:MyPageRight x:Class="PCL.PageOnlineNeteaseProxy"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:local="clr-namespace:PCL"
                   PanScroll="{Binding ElementName=PanBack}">
    <local:MyScrollViewer x:Name="PanBack"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="25,15,25,25">
            <local:MyCard Title="Netease Java 服务器代理"
                          Margin="0,0,0,15">
                <StackPanel Margin="16,42,16,16">
                    <TextBlock Text="先用 4399 或 Netease 社区账号登录，再在这里搜索服务器、选择角色并启动本地代理。"
                               TextWrapping="Wrap"
                               Opacity="0.8" />
                    <TextBlock x:Name="LabAccountState"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ColorBrush2}" />
                </StackPanel>
            </local:MyCard>

            <local:MyCard Title="服务器列表"
                          Margin="0,0,0,15">
                <StackPanel Margin="16,42,16,16">
                    <local:MySearchBox x:Name="PanSearchBox"
                                       SearchButtonVisibility="Visible"
                                       HintText="搜索网易 Java 服务器" />
                    <TextBlock x:Name="LabServerStatus"
                               Margin="0,10,0,0"
                               Foreground="{DynamicResource ColorBrush2}"
                               TextWrapping="Wrap" />
                    <local:MyLoading x:Name="LoadServers"
                                     Margin="0,10,0,0"
                                     Text="正在获取服务器列表"
                                     Visibility="Collapsed" />
                    <StackPanel x:Name="PanServers"
                                Margin="0,10,0,0" />
                    <StackPanel x:Name="PanServerPager"
                                Margin="0,10,0,0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Visibility="Collapsed">
                        <local:MyIconButton x:Name="BtnServerPrev"
                                            Margin="0,0,8,0"
                                            SvgIcon="lucide/chevron-left" />
                        <TextBlock x:Name="LabServerPage"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ColorBrush1}" />
                        <local:MyIconButton x:Name="BtnServerNext"
                                            Margin="8,0,0,0"
                                            SvgIcon="lucide/chevron-right" />
                    </StackPanel>
                </StackPanel>
            </local:MyCard>

            <local:MyCard Title="角色与启动"
                          Margin="0,0,0,15">
                <StackPanel Margin="16,42,16,16">
                    <TextBlock x:Name="LabSelectedServer"
                               Text="先从上面选择一个服务器。"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ColorBrush2}" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="36" />
                        </Grid.ColumnDefinitions>
                        <local:MyComboBox x:Name="ComboRoles"
                                          Grid.Column="0"
                                          Height="32" />
                        <local:MyIconButton x:Name="BtnRefreshRoles"
                                            Grid.Column="2"
                                            SvgIcon="lucide/refresh-cw"
                                            ToolTip="刷新角色列表" />
                    </Grid>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="110" />
                        </Grid.ColumnDefinitions>
                        <local:MyTextBox x:Name="TextNewRole"
                                         Grid.Column="0"
                                         Height="32"
                                         HintText="新角色名" />
                        <local:MyButton x:Name="BtnCreateRole"
                                        Grid.Column="2"
                                        Height="32"
                                        Text="创建角色" />
                    </Grid>
                    <local:MyButton x:Name="BtnLaunchProxy"
                                    Height="36"
                                    Margin="0,14,0,0"
                                    ColorType="Highlight"
                                    Text="启动本地代理" />
                    <TextBlock x:Name="LabRoleStatus"
                               Margin="0,10,0,0"
                               Foreground="{DynamicResource ColorBrush2}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </local:MyCard>

            <local:MyCard Title="运行中的代理与会话">
                <StackPanel Margin="16,42,16,16">
                    <local:MyLoading x:Name="LoadSessions"
                                     Text="正在刷新会话列表"
                                     Visibility="Collapsed" />
                    <TextBlock x:Name="LabSessionEmpty"
                               Margin="0,10,0,0"
                               Text="当前没有运行中的代理或启动会话。"
                               Foreground="{DynamicResource ColorBrush2}"
                               Visibility="Collapsed" />
                    <StackPanel x:Name="PanSessions"
                                Margin="0,10,0,0" />
                </StackPanel>
            </local:MyCard>
        </StackPanel>
    </local:MyScrollViewer>
</local:MyPageRight>
