<local:MyPageLeft
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:PCL" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="PCL.PageOnlineLeft"
    d:DesignWidth="152">
    <local:MyScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                          Style="{StaticResource ScrollViewerFullMargin}">
        <StackPanel Margin="0,12,0,0" x:Name="PanItem">
            <TextBlock Text="{DynamicResource Online.Nav.Category.Multiplayer}" Margin="13,5,5,3" Opacity="0.6" FontSize="12" />
            <local:MyListItem x:Name="ItemLobby" IsScaleAnimationEnabled="False" Tag="0" MinPaddingRight="35" Height="36"
                               VerticalAlignment="Top" Title="{DynamicResource Online.Nav.Lobby}" Type="RadioBox" Check="PageCheck"
                               LogoScale="0.95" SvgIcon="lucide/network" />
            <local:MyListItem x:Name="ItemCreateRoom" IsScaleAnimationEnabled="False" Tag="1" MinPaddingRight="35" Height="36"
                               VerticalAlignment="Top" Title="{DynamicResource Online.Nav.CreateRoom}" Type="RadioBox" Check="PageCheck"
                               LogoScale="0.95" SvgIcon="lucide/circle-plus" />
            <local:MyListItem x:Name="ItemServerList" IsScaleAnimationEnabled="False" Tag="2" MinPaddingRight="35" Height="36"
                               VerticalAlignment="Top" Title="{DynamicResource Online.Nav.ServerList}" Type="RadioBox" Check="PageCheck"
                               LogoScale="0.95" SvgIcon="lucide/server">
                <local:MyListItem.Buttons>
                    <x:Array Type="{x:Type local:MyIconButton}">
                        <local:MyIconButton Tag="2" ToolTip="{DynamicResource Common.Action.Refresh}"
                                            ToolTipService.Placement="Right"
                                            ToolTipService.InitialShowDelay="200" ToolTipService.VerticalOffset="-1"
                                            LogoScale="0.85" Click="RefreshButton_Click"
                                            SvgIcon="lucide/refresh-cw" />
                    </x:Array>
                </local:MyListItem.Buttons>
            </local:MyListItem>
            <local:MyListItem x:Name="ItemNeteaseProxy" IsScaleAnimationEnabled="False" Tag="5" MinPaddingRight="35" Height="36"
                               VerticalAlignment="Top" Title="Netease Java 代理" Type="RadioBox" Check="PageCheck"
                               LogoScale="0.95" SvgIcon="lucide/waypoints">
                <local:MyListItem.Buttons>
                    <x:Array Type="{x:Type local:MyIconButton}">
                        <local:MyIconButton Tag="5" ToolTip="{DynamicResource Common.Action.Refresh}"
                                            ToolTipService.Placement="Right"
                                            ToolTipService.InitialShowDelay="200" ToolTipService.VerticalOffset="-1"
                                            LogoScale="0.85" Click="RefreshButton_Click"
                                            SvgIcon="lucide/refresh-cw" />
                    </x:Array>
                </local:MyListItem.Buttons>
            </local:MyListItem>
            <TextBlock Text="{DynamicResource Online.Nav.Category.Friends}" Margin="13,5,5,3" Opacity="0.6" FontSize="12" />
            <local:MyListItem x:Name="ItemFriendList" IsScaleAnimationEnabled="False" Tag="3" MinPaddingRight="35" Height="36"
                               VerticalAlignment="Top" Title="{DynamicResource Online.Nav.FriendList}" Type="RadioBox" Check="PageCheck"
                               LogoScale="0.95" SvgIcon="lucide/users">
                <local:MyListItem.Buttons>
                    <x:Array Type="{x:Type local:MyIconButton}">
                        <local:MyIconButton Tag="3" ToolTip="{DynamicResource Common.Action.Refresh}"
                                            ToolTipService.Placement="Right"
                                            ToolTipService.InitialShowDelay="200" ToolTipService.VerticalOffset="-1"
                                            LogoScale="0.85" Click="RefreshButton_Click"
                                            SvgIcon="lucide/refresh-cw" />
                    </x:Array>
                </local:MyListItem.Buttons>
            </local:MyListItem>
            <local:MyListItem x:Name="ItemAddFriend" IsScaleAnimationEnabled="False" Tag="4" MinPaddingRight="35" Height="36"
                               VerticalAlignment="Top" Title="{DynamicResource Online.Nav.AddFriend}" Type="RadioBox" Check="PageCheck"
                               LogoScale="0.95" SvgIcon="lucide/user-plus">
                <local:MyListItem.Buttons>
                    <x:Array Type="{x:Type local:MyIconButton}">
                        <local:MyIconButton Tag="4" ToolTip="{DynamicResource Common.Action.Refresh}"
                                            ToolTipService.Placement="Right"
                                            ToolTipService.InitialShowDelay="200" ToolTipService.VerticalOffset="-1"
                                            LogoScale="0.85" Click="RefreshButton_Click"
                                            SvgIcon="lucide/refresh-cw" />
                    </x:Array>
                </local:MyListItem.Buttons>
            </local:MyListItem>
        </StackPanel>
    </local:MyScrollViewer>
</local:MyPageLeft>
