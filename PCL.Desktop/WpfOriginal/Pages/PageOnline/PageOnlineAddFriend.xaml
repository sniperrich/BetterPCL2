<local:MyPageRight x:Class="PCL.PageOnlineAddFriend"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:local="clr-namespace:PCL"
                   PanScroll="{Binding ElementName=PanBack}">
    <local:MyScrollViewer x:Name="PanBack" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="25,15,25,25">
            <local:MyCard Margin="0,0,0,15">
                <StackPanel Margin="22,18,25,18">
                    <TextBlock Text="{DynamicResource Online.Friend.Add.Title}" FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource ColorBrush1}" />
                    <TextBlock Margin="0,4,0,12" Text="{DynamicResource Online.Friend.Add.Description}"
                               FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource ColorBrush2}" />
                    <local:MySearchBox x:Name="SearchBox" HintText="{DynamicResource Online.Friend.Add.SearchHint}"
                                       SearchButtonVisibility="Visible" />
                </StackPanel>
            </local:MyCard>
            <local:MyCard x:Name="CardSearchResult" Visibility="Collapsed" Margin="0,0,0,15">
                <Grid Margin="22,18,25,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="LabSearchName" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource ColorBrush1}" />
                        <TextBlock x:Name="LabSearchId" Margin="0,4,0,0" FontSize="12"
                                   TextWrapping="Wrap" Foreground="{DynamicResource ColorBrush2}" />
                    </StackPanel>
                    <local:MyIconTextButton x:Name="BtnApply" Grid.Column="1" Height="32" MinWidth="110"
                                            Text="{DynamicResource Online.Friend.Add.Apply}" SvgIcon="lucide/user-plus"
                                            LogoScale="0.82" Click="BtnApply_Click" />
                </Grid>
            </local:MyCard>
            <local:MyCard>
                <StackPanel Margin="22,18,25,18">
                    <local:MyLoading x:Name="Load" Text="{DynamicResource Online.Friend.Add.Loading}"
                                     Margin="0,4,0,4" Visibility="Collapsed" />
                    <StackPanel x:Name="PanPassive">
                        <TextBlock Text="{DynamicResource Online.Friend.Add.Requests}" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource ColorBrush1}" />
                        <StackPanel x:Name="PanRequests" Margin="0,8,0,14" />
                        <TextBlock Text="{DynamicResource Online.Friend.Add.History}" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource ColorBrush1}" />
                        <StackPanel x:Name="PanHistory" Margin="0,8,0,0" />
                    </StackPanel>
                </StackPanel>
            </local:MyCard>
        </StackPanel>
    </local:MyScrollViewer>
</local:MyPageRight>
