<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifiers>win-x64;linux-x64;osx-x64;osx-arm64</RuntimeIdentifiers>
    <AssemblyName>PCL.Desktop</AssemblyName>
    <RootNamespace>PCL.Desktop</RootNamespace>
    <Description>PCL N cross-platform Avalonia desktop shell</Description>
    <ApplicationIcon>Assets/icon.ico</ApplicationIcon>
    <LangVersion>14.0</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AvaloniaUseCompiledBindingsByDefault>false</AvaloniaUseCompiledBindingsByDefault>
    <PublishAot>true</PublishAot>
    <PublishTrimmed>true</PublishTrimmed>
    <TrimMode>link</TrimMode>
    <BuiltInComInteropSupport>false</BuiltInComInteropSupport>
    <IlcOptimizationPreference>Speed</IlcOptimizationPreference>
    <EnableAotAnalyzer>true</EnableAotAnalyzer>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <EnableSingleFileAnalyzer>true</EnableSingleFileAnalyzer>
    <AnalysisLevel>latest-recommended</AnalysisLevel>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Avalonia.Desktop" Version="12.0.4" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="12.0.4" />
  </ItemGroup>
  <ItemGroup>
    <AvaloniaResource Include="Assets/**" />
    <AvaloniaResource Include="WpfOriginal/Images/**" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="WpfOriginal/**/*.cs" />
    <None Include="WpfOriginal/**/*.cs" />
    <None Include="WpfOriginal/**/*.xaml" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../PCL.Application/PCL.Application.csproj" />
    <ProjectReference Include="../PCL.Platform/PCL.Platform.csproj" />
    <ProjectReference Include="../PCL.Plugin/PCL.Plugin.csproj" />
    <ProjectReference Include="../PCL.UI.Abstractions/PCL.UI.Abstractions.csproj" />
  </ItemGroup>
</Project>
